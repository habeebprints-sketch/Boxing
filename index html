<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ultimate Boxing Game</title><style>
body { margin:0; background:black; color:white; font-family:Arial; overflow:hidden; }
#rotate { position:fixed; width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:24px; background:black; z-index:10; }
#game { display:none; height:100vh; width:100vw; }
.top { display:flex; justify-content:space-around; padding:10px; }
.healthbar { width:40%; height:20px; background:red; }
.health { height:100%; background:lime; width:100%; }
.ring { position:relative; width:100%; height:55%; background:#222; border-top:3px solid white; border-bottom:3px solid white; overflow:hidden; }
.fighter { position:absolute; bottom:0; width:180px; transition:0.2s; filter:drop-shadow(0 0 10px black); }
#p1 { left:50px; }
#p2 { right:50px; transform:scaleX(-1); }
.controls { display:flex; justify-content:space-around; padding:10px; }
button { padding:12px; font-size:16px; border-radius:10px; border:none; }
.timer { text-align:center; }
</style></head>
<body><div id="rotate">🔄 Rotate your phone</div><div id="game"><div class="top">
<div>
<div>Joshua 🇬🇧</div>
<div class="healthbar"><div id="h1" class="health"></div></div>
</div>
<div>
<div>Opponent (Ali 🇺🇸)</div>
<div class="healthbar"><div id="h2" class="health"></div></div>
</div>
</div><div class="timer">Round: <span id="round">1</span> | Time: <span id="time">30</span></div><div class="ring">
<img id="p1" class="fighter" src="joshua.png">
<img id="p2" class="fighter" src="ali.png">
</div><div class="controls">
<button onclick="move(-20)">⬅️</button>
<button onclick="move(20)">➡️</button>
<button onclick="attack('light')">Punch</button>
<button onclick="attack('heavy')">Heavy</button>
<button onclick="block()">Block</button>
</div></div><script>
let h1=100,h2=100,stamina=100,blocking=false;
let round=1,time=30,timer;

function checkOrientation(){
 if(window.innerWidth>window.innerHeight){
  rotate.style.display='none'; game.style.display='block';
 } else {
  rotate.style.display='flex'; game.style.display='none';
 }
}
window.addEventListener('resize',checkOrientation);
checkOrientation();

function update(){
 h1=Math.max(0,h1); h2=Math.max(0,h2);
 document.getElementById('h1').style.width=h1+'%';
 document.getElementById('h2').style.width=h2+'%';
 document.getElementById('round').innerText=round;
 document.getElementById('time').innerText=time;
}

function move(x){
 let p=document.getElementById('p1');
 let current=parseInt(p.style.left||50);
 p.style.left=(current+x)+'px';
}

function animate(id){
 let f=document.getElementById(id);
 f.style.transform='scale(1.1)';
 setTimeout(()=>f.style.transform='',150);
}

function attack(type){
 if(stamina<=0) return;
 let dmg= type==='heavy'?20:10;
 stamina-= type==='heavy'?20:10;
 if(Math.random()<0.3) dmg*=2;
 if(!blocking) h2-=dmg;
 animate('p2');
 enemyAI();
 update(); check();
}

function block(){
 blocking=true;
 setTimeout(()=>blocking=false,1000);
}

function enemyAI(){
 let move=Math.random();
 if(move<0.6){
  let dmg=10;
  if(!blocking) h1-=dmg;
  animate('p1');
 }
}

function check(){
 if(h1<=0){ knockout('You Lost'); }
 if(h2<=0){ knockout('Joshua Wins! 🏆'); }
}

function knockout(msg){
 alert(msg);
 reset();
}

function startRound(){
 time=30;
 clearInterval(timer);
 timer=setInterval(()=>{
  time--;
  if(time<=0){
    round++;
    if(round>3){ endMatch(); }
    else startRound();
  }
  update();
 },1000);
}

function endMatch(){
 clearInterval(timer);
 if(h1>h2) alert('You Win Match'); else alert('You Lose Match');
 reset();
}

function reset(){
 h1=100; h2=100; stamina=100; round=1;
 startRound(); update();
}

window.addEventListener('keydown',e=>{
 if(e.key==='a') move(-20);
 if(e.key==='d') move(20);
 if(e.key==='j') attack('light');
 if(e.key==='k') attack('heavy');
 if(e.key==='l') block();
});

startRound(); update();
</script></body>
</html>
